{
  "name": "realforge-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"NEXT,WORKER\" \"next dev -p 3001\" \"npm run worker:deepseek\"",
    "dev:next": "next dev -p 3001",
    "dev:full": "docker-compose up -d && npm run dev",
    "dev:all": "npm run dev",
    "dev:turbo": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "worker": "tsx workers/image-process.ts",
    "worker:deepseek": "tsx workers/image-process-deepseek.ts",
    "test:dev": "concurrently --kill-others-on-fail \"next dev -p 3001\" \"npm run worker:deepseek\"",
    "test:deepseek": "node test-deepseek-simple.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:run": "vitest run",
    "postinstall": "prisma generate",
    "tauri": "tauri"
  },
  "dependencies": {
