# ============================================
# REALFORGE AI - Environment Variables Example
# ============================================
# Copy this file to .env.local and fill in your values.
# Reálné klíče (DEEPSEEK_API_KEY, DATABASE_URL, NEXTAUTH_SECRET, …) ukládejte
# pouze do .env.local – ten se necommituje do gitu.
# ============================================

# Database Configuration
# PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# NextAuth.js Configuration
# URL of your application (must match the URL/port you open in the browser, e.g. 3001)
NEXTAUTH_URL="http://localhost:3001"
# Secret for signing tokens (required; generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-key-here"

# Encryption for API keys stored in DB (Sreality, Poski, optional DeepSeek from UI). Use 32+ chars or leave unset to use NEXTAUTH_SECRET.
ENCRYPTION_KEY="your-32-plus-character-encryption-key-here"

# Authentication Providers
# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email Configuration (for magic links, optional)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@yourdomain.com"

# Demo credentials (for development only)
DEMO_EMAIL="demo@realforge.ai"
DEMO_PASSWORD="demo"

# PostgreSQL credentials for Docker Compose
POSTGRES_USER="realforge"
POSTGRES_PASSWORD="your-secure-password-here"
POSTGRES_DB="realforge_ai"

# AI Services
# OpenAI API Key (for GPT-4o-mini)
OPENAI_API_KEY="sk-your-openai-api-key-here"

# DeepSeek AI API – globální fallback pro AI analýzu fotek. NEPŘEPISOVAT; worker bere klíč z DB (UI) nebo odtud.
DEEPSEEK_API_KEY="sk-pro-..."
DEEPSEEK_API_URL="https://api.deepseek.com"

# Ollama – open-source vision zdarma (místo DeepSeek). Spusť: ollama run llava
# Když je OLLAMA_BASE_URL nastavené, použije se pro kategorizaci a popisky fotek.
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_VISION_MODEL="llava"

# HuggingFace (for CLIP model, optional)
HUGGINGFACE_API_KEY=""

# Payment Processing
# Stripe API Keys
STRIPE_PUBLIC_KEY="pk_test_your_stripe_public_key"
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Redis – pro frontu jobů (upload ZIP → worker). Lokálně: docker-compose up -d redis.
REDIS_URL="redis://localhost:6379"

# ML Service Configuration
ML_SERVICE_URL="http://localhost:8000"

# Frontend Configuration (port must match NEXTAUTH_URL / dev server, e.g. 3001)
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_STRIPE_PUBLIC_KEY="pk_test_your_stripe_public_key"

# Monitoring & Analytics
# Sentry DSN (optional)
NEXT_PUBLIC_SENTRY_DSN=""

# Rate Limiting
# Upstash Redis for rate limiting (optional)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Sreality API – volitelné pro export; lze nastavit v UI (Integrace) nebo zde pro lokální testy
SREALITY_API_KEY=""
SREALITY_API_TOKEN=""
SREALITY_API_URL="https://api.sreality.cz"

# ============================================
# 🏠 Property Enrichment – auto-fill z adresy
# ============================================
# Při zadání adresy nemovitosti AI automaticky doplní GPS, letecký snímek,
# Street View foto, okolní občanskou vybavenost a srovnatelné nemovitosti.
# Server-side only (žádný NEXT_PUBLIC_ prefix) — klíče se nikdy neposílají do browseru.

# Google Maps Platform – Geocoding + Static Maps + Street View + Places
# Získat klíč: https://console.cloud.google.com/apis/credentials
# V projektu povolit tyto APIs:
#   • Geocoding API           (adresa → GPS)
#   • Maps Static API         (statický 2D obrázek mapy)
#   • Street View Static API  (foto exteriéru z ulice)
#   • Places API (New)        (POI v okolí: školy, MHD, obchody)
# Doporučení: omezit klíč pouze na tyto 4 APIs + IP své produkční domény.
# Free tier: $200 kreditu měsíčně (~28k volání). Pro 1 inzerát ~$0.05.
GOOGLE_MAPS_API_KEY=""

# Apify – Sreality scraper pro tržní data (srovnatelné inzeráty + medián cen/m²)
# Získat token: https://console.apify.com/account/integrations
# Volitelné, ale doporučené pro priceSuggestion s reálnými daty místo AI odhadu.
APIFY_API_TOKEN=""
APIFY_SREALITY_ACTOR="bebich/sreality-scraper"

# Mapy.cz API (volitelné) – fallback na ZDARMA české mapy + POI místo Google
# Vhodné pro CZ region, vyhne se Google nákladům na malých listingech.
# Získat klíč: https://developer.mapy.cz/
MAPYCZ_API_KEY=""

# ČÚZK / RUIAN – český katastr nemovitostí
# Veřejné REST API, ŽÁDNÝ KLÍČ není potřeba. Pouze base URL pro override.
RUIAN_API_URL="https://ags.cuzk.cz/arcgis2/rest/services/RUIAN/Vyhledavaci_sluzba_nad_daty_RUIAN_csv/MapServer"
CUZK_NAHLIZENI_URL="https://nahlizenidokn.cuzk.cz"

# ============================================
# Development Notes:
# 1. Required variables: DATABASE_URL, NEXTAUTH_SECRET, DEEPSEEK_API_KEY
# 2. Recommended for property auto-fill: GOOGLE_MAPS_API_KEY, APIFY_API_TOKEN
# 3. For production, use secure secrets and environment-specific values
# 4. Never commit .env.local to version control
# ============================================