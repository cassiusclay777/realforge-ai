# ============================================
# REALFORGE AI - Environment Variables Example
# ============================================
# Copy this file to .env.local and fill in your values.
# Reálné klíče (DEEPSEEK_API_KEY, DATABASE_URL, NEXTAUTH_SECRET, …) ukládejte
# pouze do .env.local – ten se necommituje do gitu.
# ============================================

# Database Configuration
# PostgreSQL connection string (musí sedět s POSTGRES_PORT níže – výchozí 5433)
# Pozn.: pokud lokálně běží Supabase Postgres na 5432, realforge-postgres v docker-compose
# používá 5433, aby nedošlo ke kolizi portů.
DATABASE_URL="postgresql://username:password@localhost:5433/database_name"

# NextAuth.js Configuration
# URL of your application (must match the URL/port you open in the browser; npm run dev uses 3050)
NEXTAUTH_URL="http://localhost:3050"
# Alternative app URL for frontend (used as fallback for image URLs in Poski export)
NEXT_PUBLIC_APP_URL="http://localhost:3050"
# Secret for signing tokens (required; generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-key-here"

# Encryption for API keys stored in DB (Sreality, Poski, optional DeepSeek from UI). Use 32+ chars or leave unset to use NEXTAUTH_SECRET.
ENCRYPTION_KEY="your-32-plus-character-encryption-key-here"

# Authentication Providers
# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email Configuration (for magic links, optional)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@yourdomain.com"

# Demo účet (jen vývoj) — `npm run db:seed` nebo automaticky při `next dev` (instrumentation)
# Heslo min. 8 znaků; kratší hodnota se ignoruje a použije se výchozí demo12345
DEMO_EMAIL="demo@realforge.ai"
DEMO_PASSWORD="demo12345"
# Vypnout auto-seed demo účtu při startu dev serveru: DEMO_AUTO_SEED=0

# PostgreSQL credentials for Docker Compose
POSTGRES_USER="realforge"
POSTGRES_PASSWORD="your-secure-password-here"
POSTGRES_DB="realforge_ai"
# Host port mapovaný na kontejner (výchozí 5433 kvůli kolizi s jiným Postgres na 5432)
POSTGRES_PORT="5433"

# Poski export – relativní URL fotek se skládají s baseUrl z handleru (NEXTAUTH_URL / VERCEL_URL).
# Ujisti se, že veřejná URL odpovídá tomu, odkud jsou fotky dostupné (viz lib/poski-real/DataMapper.ts).

# AI Services
# OpenAI API Key (for GPT-4o-mini)
OPENAI_API_KEY="sk-your-openai-api-key-here"

# DeepSeek AI API – globální fallback pro AI analýzu fotek. NEPŘEPISOVAT; worker bere klíč z DB (UI) nebo odtud.
DEEPSEEK_API_KEY="sk-pro-..."
DEEPSEEK_API_URL="https://api.deepseek.com"

# Ollama – open-source vision zdarma (místo DeepSeek). Spusť: ollama run llava
# Když je OLLAMA_BASE_URL nastavené, použije se pro kategorizaci a popisky fotek.
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_VISION_MODEL="llava"

# HuggingFace (for CLIP model, optional)
HUGGINGFACE_API_KEY=""

# Payment Processing
# Stripe API Keys
STRIPE_PUBLIC_KEY="pk_test_your_stripe_public_key"
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Redis – pro frontu jobů (upload ZIP → worker). `npm run dev` spouští přes predev Redis + Postgres (docker).
REDIS_URL="redis://localhost:6379"

# ML Service Configuration
ML_SERVICE_URL="http://localhost:8000"

# Frontend Configuration (port must match NEXTAUTH_URL / dev server, e.g. 3050)
NEXT_PUBLIC_API_URL="http://localhost:3050"
NEXT_PUBLIC_STRIPE_PUBLIC_KEY="pk_test_your_stripe_public_key"

# Monitoring & Analytics
# Sentry DSN (optional)
NEXT_PUBLIC_SENTRY_DSN=""

# Rate Limiting
# Upstash Redis for rate limiting (optional)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Sreality API – volitelné pro export; lze nastavit v UI (Integrace) nebo zde pro lokální testy
SREALITY_API_KEY=""
SREALITY_API_TOKEN=""
SREALITY_API_URL="https://api.sreality.cz"

# ============================================
# Development Notes:
# 1. Required variables: DATABASE_URL, NEXTAUTH_SECRET, OPENAI_API_KEY
# 2. For production, use secure secrets and environment-specific values
# 3. Never commit .env.local to version control
# ============================================