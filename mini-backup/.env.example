# ============================================
# REALFORGE AI - Environment Variables Example
# ============================================
# Copy this file to .env.local and fill in your values
# ============================================

# Database Configuration
# PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# NextAuth.js Configuration
# URL of your application
NEXTAUTH_URL="http://localhost:3000"
# Secret for signing tokens (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-key-here"

# Authentication Providers
# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email Configuration (for magic links, optional)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@yourdomain.com"

# Demo credentials (for development only)
DEMO_EMAIL="demo@realforge.ai"
DEMO_PASSWORD="demo"

# PostgreSQL credentials for Docker Compose
POSTGRES_USER="realforge"
POSTGRES_PASSWORD="your-secure-password-here"
POSTGRES_DB="realforge_ai"

# AI Services
# OpenAI API Key (for GPT-4o-mini)
OPENAI_API_KEY="sk-your-openai-api-key-here"

# DeepSeek AI API (alternative/fallback)
DEEPSEEK_API_KEY="your-deepseek-api-key-here"
DEEPSEEK_API_URL="https://api.deepseek.com"

# HuggingFace (for CLIP model, optional)
HUGGINGFACE_API_KEY=""

# Payment Processing
# Stripe API Keys
STRIPE_PUBLIC_KEY="pk_test_your_stripe_public_key"
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Redis Configuration (for BullMQ queues)
REDIS_URL="redis://localhost:6379"

# ML Service Configuration
ML_SERVICE_URL="http://localhost:8000"

# Frontend Configuration
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLIC_KEY="pk_test_your_stripe_public_key"

# Monitoring & Analytics
# Sentry DSN (optional)
NEXT_PUBLIC_SENTRY_DSN=""

# Rate Limiting
# Upstash Redis for rate limiting (optional)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Sreality API (for real estate data, Czech market)
SREALITY_API_KEY=""
SREALITY_API_URL="https://api.sreality.cz"

# ============================================
# Development Notes:
# 1. Required variables: DATABASE_URL, NEXTAUTH_SECRET, OPENAI_API_KEY
# 2. For production, use secure secrets and environment-specific values
# 3. Never commit .env.local to version control
# ============================================